rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Scores: anyone can read, only authenticated non-anonymous users can write their own
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
        && !request.auth.token.firebase.sign_in_provider.matches('anonymous')
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.wpm is number
        && request.resource.data.wpm >= 0
        && request.resource.data.wpm <= 300
        && request.resource.data.accuracy is number
        && request.resource.data.accuracy >= 0
        && request.resource.data.accuracy <= 100;
      allow update, delete: if false;
    }

    // Users: anyone can read profiles, users can only write their own
    match /users/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // Meta stats: read only
    match /meta/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}
