rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users Collection ──────────────────────────────────────────────────
    // Allow users to read any profile (for public leaderboard/profile pages)
    // Allow users to only write their own profile document
    match /users/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // ─── Scores Collection ─────────────────────────────────────────────────
    // Public leaderboard: anyone can read scores
    // Only authenticated users can add their own score  
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.wpm is number
        && request.resource.data.accuracy is number;
      allow update, delete: if false;
    }

    // ─── Meta collection (global stats / counters) ─────────────────────────
    match /meta/{document} {
      allow read: if true;
      allow write: if false; // Server-side only
    }
  }
}
